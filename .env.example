# Next.js → API proxy target
API_ORIGIN=http://127.0.0.1:4000

# /convert page: toman per 1 USDT when Nobitex USDT/IRT cannot be fetched (server-side)
# FALLBACK_TOMAN_PER_USDT=52000

# Next.js browser WebSocket (optional; defaults to ws(s)://<host>:4000)
# NEXT_PUBLIC_WS_URL=ws://127.0.0.1:4000

# Node API
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Postgres / Redis (docker-compose defaults)
DATABASE_URL=postgresql://etebaar:etebaar@127.0.0.1:5432/etebaar
REDIS_URL=redis://127.0.0.1:6379

# Ledger / risk (API)
SYSTEM_USER_ID=00000000-0000-0000-0000-000000000001
INTERNAL_API_SECRET=change-me-in-prod
JWT_SECRET=use-a-long-random-string-in-production
FEE_BPS=10
WITHDRAWAL_DAILY_LIMIT_USDT=100000

# Go matcher (same DATABASE_URL / REDIS_URL as API)
# MATCHING_LISTEN=:4100

# Python worker
WORKER_INTERVAL_SEC=30
REFERENCE_URL=https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT

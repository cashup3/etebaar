# Next.js → API proxy target (also used server-side to pull /internal/fx-overrides when INTERNAL_API_SECRET matches the API)
API_ORIGIN=http://127.0.0.1:4000

# Optional: override Binance REST base for /api/market/* (Vercel tries several mirrors, then CoinGecko).
# BINANCE_API_BASE=https://api.binance.com
# COINGECKO_API_BASE=https://api.coingecko.com

# --- Iranian open-market JSON for /convert (optional) --------------------------------------------
# Public HTTPS URL returning JSON. When set and valid, IRT in the calculator uses this toman/USDT anchor
# unless IRAN_RATES_DISPLAY_ONLY=true (then Nobitex stays the anchor and this feed is shown as a table only).
#
# Minimal shape:
#   { "tomanPerUsdt": 105000, "source": "My worker", "updatedAt": "2026-04-01T12:00:00Z" }
#
# Or nested USD:
#   { "usd": { "buy": 104500, "sell": 105200 }, "eur": { "sell": 121000 }, "source": "Bonbast mirror" }
#
# Or explicit rows:
#   { "tomanPerUsdt": 105000, "items": [ { "label": "دلار", "buy": 104500, "sell": 105200 } ] }
#
# Many sites (e.g. bonbast.com) need a browser token for /json — use a tiny Worker/cron to publish JSON here.
# IRAN_RATES_JSON_URL=https://your-domain.example/iran-rates.json
# IRAN_RATES_DISPLAY_ONLY=false

# Optional: override jsdelivr URL for SamadiPour/rial-exchange-rates-archive gregorian_7days.min.json (Bonbast-backed).
# When IRAN_RATES_JSON_URL is unset, the archive still supplies open-market rows and (if Nobitex/Wallex fail) the IRT anchor.
# BONBAST_ARCHIVE_JSON_URL=https://cdn.jsdelivr.net/gh/SamadiPour/rial-exchange-rates-archive@data/gregorian_7days.min.json

# /convert page: toman per 1 USDT when no live feed works (Nobitex, Wallex, env JSON, Bonbast archive, then this)
# FALLBACK_TOMAN_PER_USDT=105000

# Pakistani rupee (PKR) is not from Frankfurter: fixed as N Iranian toman (IRT) per 1 PKR (1 PKR = N toman). Default 538.
# FIXED_TOMAN_PER_PKR=538

# Next.js browser WebSocket (optional; defaults to ws(s)://<host>:4000)
# NEXT_PUBLIC_WS_URL=ws://127.0.0.1:4000

# Node API
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Postgres / Redis (docker-compose defaults)
DATABASE_URL=postgresql://etebaar:etebaar@127.0.0.1:5432/etebaar
REDIS_URL=redis://127.0.0.1:6379

# Ledger / risk (API)
SYSTEM_USER_ID=00000000-0000-0000-0000-000000000001
INTERNAL_API_SECRET=change-me-in-prod
# Long random string. Browser UI: GET http://127.0.0.1:4000/admin then paste secret (stored in sessionStorage). JSON API: /admin/api/* with header x-admin-secret.
# ADMIN_API_SECRET=change-me-admin-dashboard
JWT_SECRET=use-a-long-random-string-in-production
FEE_BPS=10
WITHDRAWAL_DAILY_LIMIT_USDT=100000

# Go matcher (same DATABASE_URL / REDIS_URL as API)
# MATCHING_LISTEN=:4100

# Python worker
WORKER_INTERVAL_SEC=30
REFERENCE_URL=https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT
